---
import SEO from "./SEO.astro";
import { type SeoType } from "@/types/index";
import "@assets/css/global.css";
import { ClientRouter } from "astro:transitions";
interface Props {
  seo: SeoType;
}

const { seo } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <SEO seo={seo}>
      <link rel="sitemap" href="/sitemap-index.xml" />
    </SEO>

    <ClientRouter />
    <script is:inline>
      !(function () {
        const applyInitialTheme = () => {
          try {
            const k = "flexilla-theme",
              l = "theme",
              s =
                localStorage.getItem(k) || localStorage.getItem(l) || "system",
              m = window.matchMedia("(prefers-color-scheme: dark)").matches
                ? "dark"
                : "light",
              r = s === "system" ? m : s,
              d = document.documentElement;
            d.classList.toggle("dark", r === "dark");
            d.setAttribute("data-theme", r);
            d.style.colorScheme = r;
          } catch (_) {}
        };

        applyInitialTheme();
        document.addEventListener("astro:after-swap", applyInitialTheme);
      })();
    </script>
  </head>
  <body
    class="overflow-x-hidden overflow-y-auto lg-overflow-y-auto bg-white dark:bg-zinc-950 text-zinc-700 dark:text-zinc-300"
  >
    <slot />
  </body>
</html>
<script>
  import { initAppTheme } from "@assets/js/theme";
  initAppTheme();
  document.addEventListener("astro:after-swap", initAppTheme);
</script>
<style is:global>
  body:before {
    content: "small";
    display: none;
  }

  @media (min-width: 768px) {
    body:before {
      content: "md";
    }
  }

  @media (min-width: 1024px) and (max-width: 1247px) {
    body:before {
      content: "lg";
    }
  }

  @media (min-width: 1248px) {
    body:before {
      content: "xl";
    }
  }
</style>
