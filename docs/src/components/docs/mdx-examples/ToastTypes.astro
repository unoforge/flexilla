<div class="flex flex-wrap items-center gap-3">
    <button data-toast-demo-success
        class="bg-emerald-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-80 transition">
        Success
    </button>
    <button data-toast-demo-error
        class="bg-red-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-80 transition">
        Error
    </button>
    <button data-toast-demo-warning
        class="bg-amber-500 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-80 transition">
        Warning
    </button>
    <button data-toast-demo-info
        class="bg-blue-600 text-white px-4 py-2 rounded-lg text-sm font-medium hover:opacity-80 transition">
        Info
    </button>
</div>

<script>
import toast from '@flexilla/toast'
document.querySelector('[data-toast-demo-success]')?.addEventListener('click', () =>
    toast.success('Settings saved successfully!')
);
document.querySelector('[data-toast-demo-error]')?.addEventListener('click', () =>
    toast.error('There was a problem.')
);
document.querySelector('[data-toast-demo-warning]')?.addEventListener('click', () =>
    toast.warning('Please review your changes.')
);
document.querySelector('[data-toast-demo-info]')?.addEventListener('click', () =>
    toast.info('A new version is available.')
);
</script>