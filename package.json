{
  "name": "flexilla",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "description": "Flexilla - Flexible UI Components Library",
  "workspaces": [
    "packages/*",
    "docs"
  ],
  "scripts": {
    "build": "bun run --filter '@flexilla/*' build",
    "clean": "bun run --filter '@flexilla/*' clean",
    "dev": "bun run --filter '@flexilla/*' dev",
    "test": "bun test",
    "typecheck": "bun run --filter '@flexilla/*' typecheck"
  },
  "devDependencies": {
    "@tsdown/css": "0.21.4",
    "@types/node": "25.5.0",
    "lerna": "9.0.7",
    "tsdown": "0.21.4",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}