{
  "name": "@flexilla/autocomplete",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Autocomplete primitive built on the headless @flexilla/select-core",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/manager": "workspace:*",
    "@flexilla/select-core": "workspace:*",
    "@flexilla/utilities": "workspace:*",
    "flexipop": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "autocomplete",
    "select",
    "headless",
    "flexilla"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "Flexilla Team"
}
