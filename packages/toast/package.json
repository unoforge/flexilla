{
  "name": "@flexilla/toast",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "A lightweight, framework-agnostic toast/notification component inspired by Sonner — works great with Alpine.js and Livewire.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "toast",
    "notification",
    "sonner",
    "alpine",
    "livewire",
    "js",
    "ts",
    "component",
    "flexilla"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "johnkat-mj"
}
