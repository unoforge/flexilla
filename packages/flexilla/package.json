{
  "name": "@flexilla/flexilla",
  "version": "2.3.1",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "A set of unstyled interactive components for building interactive, and customizable user interfaces. Open-Source",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./flexilla.css": "./dist/style.css",
    "./dropdown.css": "./public/dropdown.css",
    "./modal.css": "./public/modal.css",
    "./offcanvas.css": "./public/offcanvas.css",
    "./tabs.css": "./public/tabs.css",
    "./tooltip.css": "./public/tooltip.css"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/accordion": "workspace:*",
    "@flexilla/auto-resize-area": "workspace:*",
    "@flexilla/collapse": "workspace:*",
    "@flexilla/custom-range": "workspace:*",
    "@flexilla/dismissible": "workspace:*",
    "@flexilla/dropdown": "workspace:*",
    "@flexilla/modal": "workspace:*",
    "@flexilla/offcanvas": "workspace:*",
    "@flexilla/pin-input": "workspace:*",
    "@flexilla/popover": "workspace:*",
    "@flexilla/tabs": "workspace:*",
    "@flexilla/tooltip": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "Flexilla",
    "interactive component",
    "components library",
    "ts",
    "js",
    "ui component",
    "interactive",
    "open-source"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unoforge/flexilla.git"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "johnkat-mj"
}
