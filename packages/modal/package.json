{
  "name": "@flexilla/modal",
  "version": "2.3.7",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "A customizable modal component for creating interactive pop-up dialogs in web applications.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./modal.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/manager": "0.2.4",
    "@flexilla/utilities": "2.5.5"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "modal",
    "overlay",
    "dialog",
    "alert-dialog",
    "js",
    "ts",
    "component",
    "interactive",
    "intercative component",
    "flexilla"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "johnkat-mj",
  "gitHead": "b642d6db4a3bb9d7d8193c4374b3d2fecbe6ed2e"
}
