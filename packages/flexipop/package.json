{
  "name": "flexipop",
  "version": "0.3.4",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "Popper for flexilla",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./create-overlay": {
      "types": "./dist/create-overlay/index.d.ts",
      "import": "./dist/create-overlay/index.js",
      "require": "./dist/create-overlay/index.cjs"
    },
    "./flexipop.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "test": "vitest run --config vitest.config.ts",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/utilities": "2.5.5"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "flexilla",
    "flexilla manager"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "gitHead": "b642d6db4a3bb9d7d8193c4374b3d2fecbe6ed2e"
}
