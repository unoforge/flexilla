{
  "name": "@flexilla/collapse",
  "version": "2.1.6",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "A versatile and interactive collapse component for creating collapsible sections in web applications, conserving space and improving user experience.",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/collapsible": "workspace:*",
    "@flexilla/manager": "workspace:*",
    "@flexilla/utilities": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "collapse",
    "collapsible",
    "js",
    "ts",
    "component",
    "interactive",
    "intercative component",
    "Flexilla"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "johnkat-mj"
}
