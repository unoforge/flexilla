{
  "name": "@flexilla/dropdown",
  "version": "2.2.8",
  "private": false,
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "description": "Utilities package for flexilla library",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dropdown.css": "./dist/style.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {
    "@flexilla/manager": "workspace:*",
    "@flexilla/utilities": "workspace:*",
    "flexipop": "workspace:*"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "dropdown",
    "js",
    "ts",
    "component",
    "interactive",
    "intercative component",
    "flexilla"
  ],
  "homepage": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/unoforge/flexilla"
  },
  "bugs": {
    "url": "https://github.com/unoforge/flexilla/issues"
  },
  "license": "MIT",
  "author": "johnkat-mj"
}
