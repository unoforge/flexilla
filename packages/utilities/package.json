{
  "name": "@flexilla/utilities",
  "version": "2.5.3",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "description": "Utility functions for Flexilla",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./accessibility": {
      "types": "./dist/accessibility/index.d.ts",
      "import": "./dist/accessibility/index.js",
      "require": "./dist/accessibility/index.cjs"
    },
    "./toggler": {
      "types": "./dist/toggler/index.d.ts",
      "import": "./dist/toggler/index.js",
      "require": "./dist/toggler/index.cjs"
    },
    "./selector": {
      "types": "./dist/selector/index.d.ts",
      "import": "./dist/selector/index.js",
      "require": "./dist/selector/index.cjs"
    },
    "./dom-utilities": {
      "types": "./dist/dom-utilities/index.d.ts",
      "import": "./dist/dom-utilities/index.js",
      "require": "./dist/dom-utilities/index.cjs"
    },
    "./scroll-to-top": {
      "types": "./dist/scroll-to-top.d.ts",
      "import": "./dist/scroll-to-top.js",
      "require": "./dist/scroll-to-top.cjs"
    },
    "./dom-teleport": {
      "types": "./dist/dom-teleport.d.ts",
      "import": "./dist/dom-teleport.js",
      "require": "./dist/dom-teleport.cjs"
    },
    "./theme": {
      "types": "./dist/theme/index.d.ts",
      "import": "./dist/theme/index.js",
      "require": "./dist/theme/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "clean": "rm -rf dist",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit -p ../../tsconfig.json"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "5.9.3"
  },
  "keywords": [
    "flexilla",
    "utilities"
  ],
  "license": "MIT"
}
